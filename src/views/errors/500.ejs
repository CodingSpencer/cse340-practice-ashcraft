<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 - Server Error</title>
    <style>
        body { font-family: sans-serif; background: #fafafa; color: #333; margin: 0; padding: 2rem; }
        .error-container { max-width: 600px; margin: 4rem auto; background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-top: 5px solid #dc3545; }
        h1 { color: #dc3545; margin-top: 0; }
        pre { background: #f8f9fa; padding: 1rem; border-radius: 4px; overflow-x: auto; border: 1px solid #e9ecef; font-size: 0.9rem; }
    </style>
</head>
<body>

    <div class="error-container">
        <h1>⚠️ 500 Internal Server Error</h1>
        <p>The application encountered a deliberate test error.</p>
        
        <% if (typeof error !== 'undefined') { %>
            <p><strong>Message:</strong> <%= error %></p>
        <% } %>

        <% if (typeof stack !== 'undefined' && stack) { %>
            <h3>Stack Trace:</h3>
            <pre><%= stack %></pre>
        <% } %>

        <p><a href="/">&larr; Return to Home Page</a></p>
    </div>

</body>
</html>